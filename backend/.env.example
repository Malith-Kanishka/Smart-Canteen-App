# MongoDB Atlas Connection
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/smart_canteen?retryWrites=true&w=majority

# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# Multer Upload Configuration
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads

# CORS Configuration
CLIENT_URL=http://localhost:3000

# Optional: File paths
PROFILE_UPLOADS=./uploads/profile-pictures
FOOD_UPLOADS=./uploads/food-items
COMPLAINT_UPLOADS=./uploads/complaints
